{
  "llm": {
    "provider": "ollama",
    "url": "http://localhost:11434/api/generate",
    "model": "llama3"
  },
  "otp": {
    "ttlSeconds": 300
  },
  "log": {
    "level": "info"
  },
  "api": {
    "port": 3001,
    "secret": "change-this-secret"
  },
  "admin": {
    "number": "91XXXXXXXXXX",
    "keyword": "your-keyword",
    "pin": "your-pin",
    "db_path": "/absolute/path/to/your/orders.db",
    "business_name": "Your Business Name",
    "agent_llm": {
      "model": "gpt-4o",
      "api_key": "sk-your-openai-key-here"
    }
  },
  "flows": {
    "customer": {
      "backend": "openclaw",
      "llm": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "api_key": "sk-your-openai-key-here"
      },
      "backend_config": {
        "command": "openclaw",
        "timeout": 90
      },
      "execution": {
        "strategy": "auto",
        "tool_intents": ["support", "place_order"],
        "backend_intents": ["general_chat", "greet"],
        "backend_capabilities": {
          "conversational": true,
          "structured": false,
          "memory": true,
          "handoffs": false,
          "structured_output": false
        },
        "response_policy": {
          "max_chars": 1200,
          "strip_markdown": false,
          "disallow_patterns": ["system prompt", "internal policy"]
        }
      }
    }
  }
}
